{
  "name": "crypto-forex-api",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test src/tests/index.test.ts",
    "test:watch": "bun --watch test src/tests/index.test.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
